  
# Django
DEBUG=True
SECRET_KEY=abcdefghijklmnopqrstuvwxyz123456
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - PostgreSQL recommended for production
DB_NAME=entreskill_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis - for Celery + Channels
REDIS_URL=redis://localhost:6379/0

# Email - Gmail SMTP example
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EntreSkill Hub <noreply@entreskill.com>

# OpenAI - for AI mock interviews
OPENAI_API_KEY=sk-your-openai-key-here

# Twilio - optional for SMS/WhatsApp
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe - optional for payments
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key